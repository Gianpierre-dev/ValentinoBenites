{
  "name": "fabiola",
  "version": "0.1.0",
  "private": true,
  "description": "Ecommerce FABIOLA - storefront + mini-panel (Fase 1)",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --filter \"./apps/*\" lint",
    "test": "pnpm --filter \"./apps/*\" test"
  }
}

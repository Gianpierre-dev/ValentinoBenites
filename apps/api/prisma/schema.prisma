// Schema Prisma - Ecommerce FABIOLA (Fase 1)
// Storefront + mini-panel. El inventario kardex (entradas/salidas) es Fase 2:
// se agregarán tablas nuevas sin modificar estas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MetodoPago {
  WHATSAPP
  YAPE
  PLIN
  IZIPAY // pasarela de pago con tarjeta (integracion por modulo aislado)
}

// Flujo del pedido en el modelo hecho-a-pedido:
// PENDIENTE_PAGO -> PAGADO -> EN_PRODUCCION -> ENVIADO, mas los terminales
// CANCELADO y RECHAZADO. Renombra los estados previos (PENDIENTE/VALIDADO/RECHAZADO).
// Mapeo de datos historicos (ver migracion SQL manual):
//   PENDIENTE -> PENDIENTE_PAGO, VALIDADO -> PAGADO, RECHAZADO -> RECHAZADO.
enum EstadoPedido {
  PENDIENTE_PAGO
  PAGADO
  EN_PRODUCCION
  ENVIADO
  CANCELADO
  RECHAZADO
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String
  slug      String     @unique
  orden     Int        @default(0)
  activo    Boolean    @default(true)
  productos Producto[]
  creadoEn  DateTime   @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("categorias")
}

model Producto {
  id           String           @id @default(cuid())
  // El Producto es el MODELO (ej. "Bandolera Andina"); la unidad comprable es la
  // Variante (color). El precio del modelo es el DEFAULT heredable por sus variantes.
  nombre       String
  slug         String           @unique
  descripcion  String?
  precio       Decimal          @db.Decimal(10, 2) // precio base del modelo
  precioOferta Decimal?         @db.Decimal(10, 2)
  // Ficha tecnica (texto libre, opcional): se muestran en el detalle del producto.
  material     String? // ej. "Cuero sintetico de alta calidad"
  dimensiones  String? // ej. "Alto 26 cm - Ancho 30 cm - Fondo 12 cm"
  activo       Boolean          @default(true)
  destacado    Boolean          @default(false)
  // Categoria OPCIONAL: un producto puede existir sin clasificar. La admin
  // crea las familias y asigna productos cuando quiere (catalogo plano por defecto).
  categoriaId  String?
  categoria    Categoria?       @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  imagenes     ImagenProducto[] // fotos del modelo (fallback cuando la variante no tiene foto propia)
  variantes    Variante[]
  items        ItemPedido[]
  creadoEn     DateTime         @default(now())
  actualizadoEn DateTime        @updatedAt

  @@index([categoriaId])
  @@index([activo])
  @@map("productos")
}

model ImagenProducto {
  id         String   @id @default(cuid())
  url        String
  orden      Int      @default(0)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@map("imagenes_producto")
}

// Variante = un color concreto de un modelo. Es la UNIDAD COMPRABLE.
// Modelo hecho-a-pedido: SIN stock ni disponibilidad por inventario; siempre disponible.
// Punto de extension futuro (NO implementar ahora): agregar `talla String?` y el
// indice unico compuesto @@unique([productoId, color, talla]) para una matriz color x talla.
model Variante {
  id           String           @id @default(cuid())
  productoId   String
  producto     Producto         @relation(fields: [productoId], references: [id], onDelete: Cascade)
  color        String // etiqueta legible ("Vino", "Rosa")
  colorHex     String? // swatch opcional (#7D2181)
  // Override OPCIONAL del precio del modelo. Precio efectivo:
  // variante.precioOferta ?? variante.precio ?? producto.precioOferta ?? producto.precio
  precio       Decimal?         @db.Decimal(10, 2)
  precioOferta Decimal?         @db.Decimal(10, 2)
  activo       Boolean          @default(true)
  orden        Int              @default(0) // orden de miniaturas en la ficha
  imagenes     ImagenVariante[] // fotos propias OPCIONALES (fallback a Producto.imagenes)
  items        ItemPedido[]
  creadoEn     DateTime         @default(now())
  actualizadoEn DateTime        @updatedAt

  @@index([productoId])
  @@index([activo])
  @@map("variantes")
}

model ImagenVariante {
  id         String   @id @default(cuid())
  url        String
  orden      Int      @default(0)
  varianteId String
  variante   Variante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@index([varianteId])
  @@map("imagenes_variante")
}

model Pedido {
  id            String       @id @default(cuid())
  codigo        String       @unique
  nombreCliente String
  telefono      String
  total         Decimal      @db.Decimal(10, 2)
  metodoPago    MetodoPago
  estado        EstadoPedido @default(PENDIENTE_PAGO)
  comprobanteUrl String?
  // Pedido payment-agnostic: no conoce la pasarela. Campos genericos de pago.
  referenciaTransaccion String? // orderId/transactionId de Izipay; null en pagos manuales
  proveedorPago         String? // "IZIPAY" | null
  rawPago               Json? // payload crudo del callback (auditoria/debug)
  items         ItemPedido[]
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  @@index([estado])
  @@map("pedidos")
}

model ItemPedido {
  id             String    @id @default(cuid())
  pedidoId       String
  pedido         Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId     String // se mantiene: referencia al modelo
  producto       Producto  @relation(fields: [productoId], references: [id])
  // Referencia viva a la variante comprada. Nullable por compatibilidad con los
  // pedidos historicos (creados antes de existir Variante).
  varianteId     String?
  variante       Variante? @relation(fields: [varianteId], references: [id])
  nombreProducto String // snapshot: "Bandolera Andina"
  colorElegido   String? // snapshot del color a fabricar ("Vino"); null en historicos
  precioUnitario Decimal   @db.Decimal(10, 2)
  cantidad       Int
  subtotal       Decimal   @db.Decimal(10, 2)

  @@index([pedidoId])
  @@index([productoId])
  @@index([varianteId])
  @@map("items_pedido")
}

// Libro de Reclamaciones virtual (Ley 29571 + DS 011-2011, mod. DS 101-2022):
// obligatorio para proveedores que venden por pagina web. RECLAMO = disconformidad
// con el producto/servicio; QUEJA = malestar con la atencion. Plazo legal de
// respuesta: 15 dias habiles.
enum TipoReclamo {
  RECLAMO
  QUEJA
}

enum EstadoReclamo {
  PENDIENTE
  RESPONDIDO
}

model Reclamo {
  id               String        @id @default(cuid())
  codigo           String        @unique // hoja de reclamacion: LR-2026-0001
  tipo             TipoReclamo
  nombreCompleto   String
  documento        String // DNI o carnet de extranjeria
  domicilio        String
  telefono         String
  email            String?
  esMenorDeEdad    Boolean       @default(false)
  apoderado        String? // padre/madre o apoderado, obligatorio si es menor
  descripcionBien  String // producto o servicio materia del reclamo
  montoReclamado   Decimal?      @db.Decimal(10, 2)
  detalle          String
  pedidoConsumidor String // lo que el consumidor solicita
  respuesta        String?
  estado           EstadoReclamo @default(PENDIENTE)
  creadoEn         DateTime      @default(now())
  respondidoEn     DateTime?
  actualizadoEn    DateTime      @updatedAt

  @@index([estado])
  @@map("reclamos")
}

model Configuracion {
  id        String   @id @default(cuid())
  whatsapp  String?
  // Identificacion legal del proveedor (Codigo del Consumidor): se muestra en el
  // footer y en la hoja del Libro de Reclamaciones. Administrable desde el admin.
  razonSocial String?
  ruc         String?
  direccion   String?
  datosYape String?
  datosPlin String?
  // QR de pago (URLs de imagen subidas a Wasabi). Se muestran al cliente en el
  // checkout cuando elige Yape/Plin. Administrable desde el panel admin.
  qrYape    String?
  qrPlin    String?
  // Redes sociales: se guarda el usuario/handle (no la URL completa); el
  // frontend arma la URL final. Administrable desde el panel admin.
  instagram String?
  facebook  String?
  tiktok    String?
  banners   Json?
  // Texto del hero de la home, administrable desde el panel admin. En heroTitulo
  // se puede resaltar UNA palabra envolviendola en asteriscos, ej:
  // "Moda que te *acompana* todos los dias" -> "acompana" se pinta con el acento.
  heroTitulo     String?
  heroSubtitulo  String?
  // true = texto claro (blanco) para banners oscuros; false = texto oscuro.
  heroTextoClaro Boolean @default(true)
  // Barra de anuncios (marquee) sobre el encabezado. barraActiva prende/apaga la
  // tira; barraAnuncios guarda la lista de mensajes (array de strings) que se
  // desplazan en loop. Administrable desde el panel admin.
  barraActiva   Boolean @default(true)
  barraAnuncios Json?
  actualizadoEn DateTime @updatedAt

  @@map("configuracion")
}

// Suscriptores del newsletter. El registro implica consentimiento informado
// (Ley 28493 antispam): el formulario lo declara junto a la politica de privacidad.
model Suscriptor {
  id       String   @id @default(cuid())
  email    String   @unique
  creadoEn DateTime @default(now())

  @@map("suscriptores")
}

model Usuario {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nombre       String?
  creadoEn     DateTime @default(now())

  @@map("usuarios")
}
